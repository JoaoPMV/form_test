<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/assets/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <title>Document</title>
</head>

<body>
  <section class="container mt-3 p-0">
    <div class="form-desktop-background">
      <div class="row p-0 m-0">

        <div class="col-lg-6 text-white px-5 mt-1">
          <h2 class="form-contact">CONTATO</h2>
          <h6 class="form-description">Este formulário é somente um treino, que consiste
            em salvar as informações em um Banco de Dados do Postgres.
          </h6>
        </div>
        <div class="col-lg-6">
          <form action="/formulario" method="POST" class="formulario py-3">
            <div class="row">
              <div class="col-sm-12 col-lg-6 d-flex flex-column py-2">
                <label for="email">Email:</label>
                <input type="text" name="email" placeholder="Digite seu email">
              </div>
              <div class="col-sm-12 col-lg-6 d-flex flex-column py-2">
                <label for="name">Nome Completo:</label>
                <input type="text" name="name" placeholder="Digite seu nome completo">
              </div>
              <div class="col-sm-12 col-lg-6 d-flex flex-column py-2">
                <label for="profession">Profissão:</label>
                <input type="text" name="profession" placeholder="Digite sua profissão">
              </div>
              <div class="col-sm-12 col-lg-6 d-flex flex-column py-2">
                <label for="city">Cidade:</label>
                <input type="text" name="city" placeholder="Digite sua cidade" required>
              </div>
              <div class="col-sm-12 d-flex flex-column py-2">
                <label for="">Mensagem:</label>
                <textarea name="content" id=""></textarea>
              </div>
              <div class="col-sm-12 text-end">
                <button type="submit" class="btn btn-light mt-3">ENVIAR</button>
              </div>
            </div>
          </form>
        </div>

      </div>
    </div>
  </section>
</body>

</html>